{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cargo build *)",
      "Bash(cargo test *)",
      "Bash(cargo clippy *)",
      "Bash(cargo fmt *)",
      "Bash(cargo doc *)",
      "Bash(cargo deny *)",
      "Bash(cargo run --bin gala *)",
      "Bash(cargo check *)",
      "Bash(git *)",
      "Bash(pre-commit *)",
      "Bash(bun *)",
      "Bash(npx *)",
      "Bash(python *)",
      "Read(Cargo.lock)",
      "Read(Cargo.toml)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)",
      "Bash(cargo publish *)",
      "Bash(cargo install *)"
    ]
  },
  "env": {
    "CARGO_TERM_COLOR": "always",
    "RUSTFLAGS": "-D warnings",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "autoMemoryEnabled": true,
  "disableBundledSkills": false
}
