{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gala-lang.org/schemas/property_result.v1.json",
  "title": "Gala Property Test Result",
  "version": "1.0.0",
  "type": "object",
  "required": ["property", "passed", "details"],
  "properties": {
    "property": {
      "type": "string",
      "enum": ["unitary", "reversible", "uncomputes", "grad_matches", "effect_honesty"]
    },
    "passed": { "type": "boolean" },
    "details": {
      "type": "object",
      "properties": {
        "function_name": { "type": "string" },
        "num_trials": { "type": "integer" },
        "tolerance": { "type": "number" },
        "max_error": { "type": "number" },
        "counterexample": { "type": "object" },
        "matrix_norm_diff": { "type": "number" },
        "fidelity": { "type": "number" }
      }
    },
    "duration_ms": { "type": "integer" }
  }
}