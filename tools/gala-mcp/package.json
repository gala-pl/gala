{
  "name": "gala-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for the Gala quantum-classical programming language",
  "type": "module",
  "bin": {
    "gala-mcp": "dist/server.js"
  },
  "scripts": {
    "build": "vite build && node scripts/copy-schemas.js",
    "dev": "bun --watch src/server.ts",
    "start": "bun dist/server.js",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "inspect": "npx @modelcontextprotocol/inspector dist/server.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gala",
    "quantum",
    "compiler",
    "language-server"
  ],
  "author": "Gala Language Team",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "vite": "^5.0.0",
    "@biomejs/biome": "^1.9.0",
    "ultracite": "^4.0.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "trustedDependencies": [
    "@modelcontextprotocol/sdk",
    "vitest",
    "vite"
  ]
}
