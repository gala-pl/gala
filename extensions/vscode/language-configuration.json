{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "/// ", "close": "", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{[^}\"']*$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\s{}()\\[\\]<>:;\".,+=*/&|%!~`@^?\\\\-]+)",
  "onEnterRules": [
    {
      "beforeText": "^\\s*\\/\\/.*",
      "action": { "indent": "none" }
    },
    {
      "beforeText": "^.*\\{\\s*$",
      "afterText": "^\\s*\\}",
      "action": { "indent": "indentOutdent" }
    },
    {
      "beforeText": "^.*\\{\\s*$",
      "action": { "indent": "indent" }
    }
  ]
}