{
  "$schema": "https://raw.githubusercontent.com/martinusso/vscode-schema-grammar/master/schema/grammar.json",
  "name": "Gala",
  "scopeName": "source.gala",
  "fileTypes": [
    "gala"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#doc-comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#effects"
    },
    {
      "include": "#quantum-keywords"
    },
    {
      "include": "#gates"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#lambda"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.gala",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        },
        {
          "name": "comment.line.double-slash.gala",
          "match": "//.*$"
        }
      ]
    },
    "doc-comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.gala",
          "begin": "///",
          "end": "$",
          "captures": {
            "0": {
              "name": "punctuation.definition.comment.gala"
            }
          }
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.gala",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.gala"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.gala"
        }
      },
      "patterns": [
        {
          "name": "constant.character.escape.gala",
          "match": "\\\\[nrt0\\\\\"']"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.complex.gala",
          "match": "\\b\\d+[iIjJ]\\b"
        },
        {
          "name": "constant.numeric.float.gala",
          "match": "\\b\\d+\\.\\d*([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.hex.gala",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.integer.binary.gala",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.integer.gala",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.gala",
          "match": "\\b(if|else|match|for|in|while|return|drop)\\b"
        },
        {
          "name": "keyword.declaration.gala",
          "match": "\\b(fn|let|mut|import|from|as|type|struct|enum|trait|impl|const|where)\\b"
        },
        {
          "name": "constant.language.gala",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.gala",
          "match": "\\b(Qubit|Qubits|Measured|Bool|Int|Float|Complex|Vec|Params|String|Unit|Self)\\b"
        }
      ]
    },
    "effects": {
      "patterns": [
        {
          "name": "storage.type.effect.gala",
          "match": "\\b(pure|quantum|prob)\\b"
        }
      ]
    },
    "quantum-keywords": {
      "patterns": [
        {
          "name": "keyword.quantum.gala",
          "match": "\\b(qubit|qubits|measure|reverse|adjoint|control|grad|drop)\\b"
        }
      ]
    },
    "gates": {
      "patterns": [
        {
          "name": "support.function.gate.gala",
          "match": "\\b(h|x|y|z|s|t|rx|ry|rz|cx|cz|swap)\\b"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.gala",
          "match": "\\b(print|println|assert|len|qubit|qubits|measure|reverse|adjoint|control|grad|drop|sample|expectation|distribution|backend)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.gala",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.gala",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.gala",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.gala",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.gala",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.gala",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.pipe.gala",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.bitwise.gala",
          "match": "&|\\|"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "begin": "(?<=\\bfn\\s+)([A-Za-z_][A-Za-z0-9_]+)(?=\\s*\\()",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.gala"
            }
          },
          "end": "(?=\\{|;)",
          "patterns": [
            {
              "include": "#types"
            },
            {
              "include": "#effects"
            },
            {
              "include": "#keywords"
            },
            {
              "match": ",",
              "name": "punctuation.delimiter.gala"
            },
            {
              "match": ":",
              "name": "punctuation.delimiter.gala"
            },
            {
              "match": "\\(|\\)",
              "name": "punctuation.bracket.gala"
            },
            {
              "match": "<|>",
              "name": "punctuation.parameter-bracket.gala"
            }
          ]
        }
      ]
    },
    "lambda": {
      "patterns": [
        {
          "begin": "\\|",
          "beginCaptures": {
            "0": {
              "name": "keyword.operator.pipe.gala"
            }
          },
          "end": "\\|",
          "endCaptures": {
            "0": {
              "name": "keyword.operator.pipe.gala"
            }
          },
          "patterns": [
            {
              "match": ":",
              "name": "punctuation.delimiter.gala"
            },
            {
              "include": "#types"
            }
          ]
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.parameter.generic.gala",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b(?!\\s*\\()"
        },
        {
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.gala",
          "match": "\\{|\\}|\\(|\\)|\\[|\\]"
        },
        {
          "name": "punctuation.delimiter.gala",
          "match": ",|;|:"
        },
        {
          "name": "punctuation.accessor.gala",
          "match": "\\."
        },
        {
          "name": "punctuation.angle-bracket.gala",
          "match": "<|>"
        }
      ]
    }
  }
}