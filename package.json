{
  "name": "gala-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "The Gala programming language monorepo",
  "scripts": {
    "build": "cargo build --workspace",
    "test": "cargo test --workspace",
    "lint": "cargo clippy --workspace -- -D warnings",
    "fmt": "cargo fmt --all",
    "clean": "cargo clean",
    "docs:dev": "cd apps/docs && bun next dev",
    "docs:build": "cd apps/docs && bun next build",
    "docs:typecheck": "cd apps/docs && bun tsc --noEmit"
  }
}
